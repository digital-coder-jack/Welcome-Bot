# ==========================================================
# Discord Moderation & Notification Backend Configuration
# Copy this file to ".env" and fill in the real values.
# ==========================================================

# --- Groq (AI moderation) ---
# Groq API key -> https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Groq model used for moderation analysis.
# See https://console.groq.com/docs/models for current options.
GROQ_MODEL=llama-3.3-70b-versatile

# --- Telegram (notifications) ---
# Bot token from @BotFather -> https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Chat ID to receive notifications (user, group or channel id).
# Get it by messaging your bot and calling getUpdates, or via @userinfobot.
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# --- Server ---
HOST=0.0.0.0
PORT=8000

# Confidence floor: analyses below this are downgraded to "no action".
MIN_CONFIDENCE=0.5
# Forge Protocol v4: a formal WARNING requires >= 95% confidence.
MIN_WARN_CONFIDENCE=0.95

# Comma-separated origins allowed by CORS (usually not needed for the bot).
ALLOWED_ORIGINS=*

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
