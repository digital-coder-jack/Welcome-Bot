# ==========================================================
# AI Moderation Backend (FastAPI + Groq) Configuration
# Copy this file to ".env" and fill in the real values.
# ==========================================================

# Groq API key -> https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Groq model used for moderation analysis.
# See https://console.groq.com/docs/models for current options.
GROQ_MODEL=llama-3.3-70b-versatile

# Server bind address / port
HOST=0.0.0.0
PORT=8000

# Confidence floor: analyses below this are downgraded to "no action".
MIN_CONFIDENCE=0.5

# Comma-separated origins allowed by CORS (usually not needed for the bot).
ALLOWED_ORIGINS=*

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
