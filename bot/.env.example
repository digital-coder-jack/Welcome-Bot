# =============================================================
# Discord Bot Configuration
# Copy this file to bot/.env and fill in the real values.
# =============================================================

# --- Discord credentials (from https://discord.com/developers/applications) ---
DISCORD_TOKEN=your-bot-token
CLIENT_ID=your-application-client-id
GUILD_ID=your-guild-id

# --- Channel & Role IDs (right-click -> Copy ID with Developer Mode on) ---
WELCOME_CHANNEL_ID=
GOODBYE_CHANNEL_ID=
LOG_CHANNEL_ID=
DEV_INTRO_CHANNEL_ID=
FORGE_MEMBER_ROLE_ID=

# --- Premium welcome buttons & moderation alerts (all optional) ---
RULES_CHANNEL_ID=            # 📖 Rules button target
COMMUNITY_CHANNEL_ID=        # 🎮 Community button target
SUPPORT_CHANNEL_ID=          # 🛟 Support button target (welcome DM)
MOD_ALERT_CHANNEL_ID=        # 🚨 default moderation-approval-panel channel

# --- AI + Telegram Backend (FastAPI on Vercel) ---
AI_BACKEND_URL=https://welcome-bot-bice.vercel.app
AI_REQUEST_TIMEOUT_MS=8000

# --- Auto-moderation tuning (optional, sane defaults applied in config.js) ---
SPAM_MESSAGE_LIMIT=5
SPAM_TIME_WINDOW_MS=7000
MAX_MENTIONS=5
MAX_EMOJIS=10
CAPS_PERCENT_THRESHOLD=70
CAPS_MIN_LENGTH=10

# --- Moderation policy ---
# Warnings before a Moderator Approval Panel is raised.
# NOTE: The bot NEVER kicks or bans automatically — reaching this threshold
# only posts an approval panel for human moderators.
MAX_WARNINGS=3

# =============================================================
# Forge Guardian Security System v2.0 (all optional, safe defaults)
# =============================================================

# --- Master switches ---
SECURITY_JOIN_SCAN_ENABLED=true       # Phase 1: complete join security scan
SECURITY_LIVE_SCAN_ENABLED=true       # Phase 2: live message threat detection
SECURITY_ANTI_RAID_ENABLED=true       # Phase 3: raid detection + Raid Mode
SECURITY_AI_ANALYSIS_ENABLED=true     # Phase 4: Groq AI security engine

# --- Account-age thresholds (days) ---
SECURITY_NEW_ACCOUNT_DAYS=7           # younger => "new account"
SECURITY_RECENT_ACCOUNT_DAYS=30       # younger => "recently created"

# --- Anti-raid tuning ---
SECURITY_RAID_JOINS=10                # joins within window that trigger Raid Mode
SECURITY_RAID_WINDOW_SEC=30           # rolling detection window (seconds)
SECURITY_RAID_MODE_MINUTES=15         # Raid Mode auto-disables after this
SECURITY_RAID_SLOWMODE_SEC=30         # slowmode applied to locked channels
SECURITY_RAID_LOCK_CHANNEL_IDS=       # comma-separated channel IDs to lock

# --- Security channels ---
SECURITY_ALERT_CHANNEL_ID=            # Owner Approval security alerts (falls back to MOD_ALERT/LOG)
SECURITY_REPORT_CHANNEL_ID=           # post-join Security Report (falls back to alert channel)
SECURITY_JOIN_REPORT_ENABLED=true     # post the Security Report after every join

# --- Owner Approval System ---
SECURITY_APPROVAL_THRESHOLD=61        # risk score >= this raises an approval alert (HIGH band)
SECURITY_TIMEOUT_MINUTES=60           # duration of the 🟡 Timeout button

# =============================================================
# Forge Guardian v2.0 — Phases 6-8 (Dashboard, Profiles, Advanced Protection)
# Every channel below is OPTIONAL — unset channels are silently skipped.
# =============================================================

# --- Dedicated security channels (all optional) ---
SECURITY_LOG_CHANNEL_ID=              # 📜 mirrored security event log
AI_ANALYSIS_CHANNEL_ID=               # 🤖 mirrored AI analysis events
SECURITY_DASHBOARD_CHANNEL_ID=        # 📊 reserved for auto-posted dashboards
# (SECURITY_ALERT_CHANNEL_ID is defined above in the v2.0 section)
# (WELCOME_CHANNEL_ID / RULES_CHANNEL_ID / SUPPORT_CHANNEL_ID defined above)
DEVINTRO_CHANNEL_ID=                  # alias for DEV_INTRO_CHANNEL_ID (either works)
