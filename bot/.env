# ==========================================================
# Discord Bot Configuration
# Fill in the real values (this file is git-ignored).
# ==========================================================

# --- Discord credentials (from https://discord.com/developers/applications) ---
DISCORD_TOKEN=your-bot-token-here
CLIENT_ID=your-application-client-id
GUILD_ID=your-development-guild-id

# --- Channel & Role IDs (right-click -> Copy ID with Developer Mode on) ---
WELCOME_CHANNEL_ID=
GOODBYE_CHANNEL_ID=
LOG_CHANNEL_ID=
DEV_INTRO_CHANNEL_ID=
FORGE_MEMBER_ROLE_ID=

# --- AI + Telegram Backend (FastAPI on Vercel) ---
AI_BACKEND_URL=https://welcome-bot-bice.vercel.app
AI_REQUEST_TIMEOUT_MS=8000

# --- Auto-moderation tuning (optional, sane defaults applied in config.js) ---
SPAM_MESSAGE_LIMIT=5
SPAM_TIME_WINDOW_MS=7000
MAX_MENTIONS=5
MAX_EMOJIS=10
CAPS_PERCENT_THRESHOLD=70
CAPS_MIN_LENGTH=10

# --- Moderation policy ---
MAX_WARNINGS=3
