# ── Developer Forge — Welcome & Onboarding System ──────────────
# Copy this file to .env and fill in your values. NEVER commit .env.

# Discord bot token (required) — https://discord.com/developers/applications
# Enable these Privileged Gateway Intents: SERVER MEMBERS, MESSAGE CONTENT
DISCORD_TOKEN=your-discord-bot-token

# Telegram owner notifications (recommended)
# 1. Create a bot with @BotFather → get the token
# 2. Send /start to your bot, then get your chat id from
#    https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MAX_RETRIES=3

# ── Security module (Part 2) ───────────────────────────────────
# AI moderation via Groq (recommended) — https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Alternative: point at the existing FastAPI moderation backend instead
# (leave GROQ_API_KEY empty to use this)
MODERATION_API_URL=

# Storage & logging
DATABASE_PATH=data/developer_forge.db
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log

# Global branding defaults (per-guild /forge settings override these)
EMBED_COLOR=3049182            # 0x2E86DE tech blue (decimal)
WEBSITE_URL=https://developerforge.dev
BRANDING=Developer Forge
EMBED_FOOTER=Developer Forge • Build. Learn. Ship.
UNLOCK_REACTION=🔥

# ── v2.0 Member Intelligence ────────────────────────────────────
# Optional privileged PRESENCES intent (also enable it in the Discord
# Developer Portal). Adds live status/activity to member records.
ENABLE_PRESENCE_INTENT=false
